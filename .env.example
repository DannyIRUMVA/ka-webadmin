# Public Nuxt runtime config (exposed to the browser)
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_ANON_KEY=
NUXT_PUBLIC_ADMIN_BASE_URL=https://platform.kakofi.com

# Server-only Supabase admin access (never expose to the client)
# Any of these variable names is accepted by the server runtime.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=
SERVICEKEY=

# Server-only system health targets
SYSTEM_HEALTH_STRIPE_WORKER_URL=
SYSTEM_HEALTH_LOCAL_PAYMENT_WORKER_URL=
SYSTEM_HEALTH_R2_UPLOADER_WORKER_URL=
SYSTEM_HEALTH_MUX_STATUS_URL=